@model IEnumerable<RpgBuilderMvc.Domain.Entities.Character>

@{
    ViewData["Title"] = "Painel";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="layout-container flex h-full grow flex-col">
    <div class="flex flex-1 flex-col">
        <main class="flex-1 p-6 md:p-10 w-full">
            <div class="max-w-6xl mx-auto">

                <div class="flex flex-wrap justify-between items-end gap-6 mb-8">
                    <div class="flex flex-col gap-2">
                        <h2 class="text-slate-900 dark:text-slate-100 text-4xl font-black leading-tight tracking-tight font-display">
                            Meus Personagens
                        </h2>
                        <p class="text-slate-500 dark:text-slate-400 text-lg">
                            Gerencie seus personagens.
                        </p>
                    </div>
                    <a asp-controller="Characters"
                       asp-action="Create"
                       class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-blue-600 text-white text-sm font-bold tracking-wide hover:brightness-110 transition-all shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined">add</span>
                        <span>Criar novo personagem</span>
                    </a>
                </div>


                <div class="mt-8 rounded-2xl bg-blue-550/80 dark:bg-blue-550/70 border border-blue-550/70 shadow-xl p-6 md:p-8">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        @foreach (var ch in Model)
                        {
                            <div class="group flex flex-col p-6 rounded-xl border border-primary/10 bg-slate-50 dark:bg-primary/5 hover:border-primary/40 transition-all">
                                <div class="flex justify-between items-start mb-4">
                                    <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                        <span class="material-symbols-outlined text-3xl">auto_fix_high</span>
                                    </div>
                                </div>
                                <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-display mb-1">
                                    @ch.Name
                                </h3>
                                <div class="flex flex-col gap-1 text-slate-500 dark:text-slate-400 text-sm mb-6">
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-sm">person</span>
                                        <span>@ch.RaceName • @ch.ClassName</span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="material-symbols-outlined text-sm">military_tech</span>
                                        <span class="font-bold text-primary">Nível @ch.Level</span>
                                    </div>
                                </div>
                                <div class="mt-auto flex gap-2">
                                    <a asp-controller="Characters"
                                       asp-action="Edit"
                                       asp-route-id="@ch.Id"
                                       class="flex-1 py-2.5 rounded-lg bg-primary/10 text-primary text-sm font-bold hover:bg-primary hover:text-white transition-all text-center">
                                        Ver ficha do personagem
                                    </a>
                                    <form asp-controller="Characters"
                                          asp-action="Delete"
                                          asp-route-id="@ch.Id"
                                          method="post"
                                          class="flex items-stretch">
                                        <button type="submit"
                                                title="Excluir"
                                                onclick="return confirm('Tem certeza que deseja excluir @ch.Name?');"
                                                class="px-3 rounded-lg bg-red-500/10 text-red-600 hover:bg-red-500 hover:text-white transition-all flex items-center justify-center">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>

                    @if (totalPages > 1)
                    {
                        <div class="mt-6 flex justify-center gap-2">
                            @if (currentPage > 1)
                            {
                                <a asp-action="Index"
                                   asp-route-page="@(currentPage - 1)"
                                   class="px-3 py-2 rounded-lg border border-border-dark text-sm text-muted-dark hover:bg-surface-dark">
                                    Anterior
                                </a>
                            }

                            @for (var p = 1; p <= totalPages; p++)
                            {
                                <a asp-action="Index"
                                   asp-route-page="@p"
                                   class="px-3 py-2 rounded-lg text-sm @(p == currentPage ? "bg-primary text-white" : "border border-border-dark text-muted-dark hover:bg-surface-dark")">
                                    @p
                                </a>
                            }

                            @if (currentPage < totalPages)
                            {
                                <a asp-action="Index"
                                   asp-route-page="@(currentPage + 1)"
                                   class="px-3 py-2 rounded-lg border border-border-dark text-sm text-muted-dark hover:bg-surface-dark">
                                    Próxima
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>
</div>