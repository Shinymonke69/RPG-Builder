@{
    ViewData["Title"] = "Painel";
}

<div class="layout-container flex h-full grow flex-col">

    <div class="flex flex-1 flex-col">
        <main class="flex-1 p-6 md:p-10 w-full">
            <div class="max-w-6xl mx-auto">

                <div class="flex flex-wrap justify-between items-end gap-6 mb-8">
                    <div class="flex flex-col gap-2">
                        <h2 class="text-slate-900 dark:text-slate-100 text-4xl font-black leading-tight tracking-tight font-display">
                            Meus Personagens
                        </h2>
                        <p class="text-slate-500 dark:text-slate-400 text-lg">
                            Gerencie seus personagens.
                        </p>
                    </div>
                    <a asp-controller="Characters" asp-action="Create" class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-primary text-white text-sm font-bold tracking-wide hover:brightness-110 transition-all shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined">add</span>
                        <span>Criar novo personagem</span>
                    </a>
                </div>

                <div class="flex gap-3 mb-8 overflow-x-auto pb-2">
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-primary/20 px-5 text-primary text-sm font-bold">
                        Todos
                    </button>
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-slate-200 dark:bg-primary/5 px-5 text-slate-600 dark:text-slate-300 text-sm font-medium hover:bg-primary/10">
                        Ativos
                    </button>
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-slate-200 dark:bg-primary/5 px-5 text-slate-600 dark:text-slate-300 text-sm font-medium hover:bg-primary/10">
                        Arquivados
                    </button>
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-slate-200 dark:bg-primary/5 px-5 text-slate-600 dark:text-slate-300 text-sm font-medium hover:bg-primary/10">
                        Favoritos
                    </button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

                    <div class="group flex flex-col p-6 rounded-xl border border-primary/10 bg-slate-50 dark:bg-primary/5 hover:border-primary/40 transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                <span class="material-symbols-outlined text-3xl">auto_fix_high</span>
                            </div>
                            <span class="px-3 py-1 rounded-full bg-green-500/10 text-green-500 text-xs font-bold uppercase tracking-wider">
                                Ativo
                            </span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-display mb-1">
                            Thaelin Silverleaf
                        </h3>
                        <div class="flex flex-col gap-1 text-slate-500 dark:text-slate-400 text-sm mb-6">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">person</span>
                                <span>Elfo • Mago</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">military_tech</span>
                                <span class="font-bold text-primary">Nível 8</span>
                            </div>
                        </div>
                        <button class="mt-auto w-full py-2.5 rounded-lg bg-primary/10 text-primary text-sm font-bold hover:bg-primary hover:text-white transition-all">
                            Ver ficha do personagem
                        </button>
                    </div>

                    <div class="group flex flex-col p-6 rounded-xl border border-primary/10 bg-slate-50 dark:bg-primary/5 hover:border-primary/40 transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                <span class="material-symbols-outlined text-3xl">shield</span>
                            </div>
                            <span class="px-3 py-1 rounded-full bg-green-500/10 text-green-500 text-xs font-bold uppercase tracking-wider">
                                Ativo
                            </span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-display mb-1">
                            Grog Strongjaw
                        </h3>
                        <div class="flex flex-col gap-1 text-slate-500 dark:text-slate-400 text-sm mb-6">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">person</span>
                                <span>Orc • Bárbaro</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">military_tech</span>
                                <span class="font-bold text-primary">Nível 12</span>
                            </div>
                        </div>
                        <button class="mt-auto w-full py-2.5 rounded-lg bg-primary/10 text-primary text-sm font-bold hover:bg-primary hover:text-white transition-all">
                            Ver ficha do personagem
                        </button>
                    </div>

                    <div class="group flex flex-col p-6 rounded-xl border border-primary/10 bg-slate-50 dark:bg-primary/5 hover:border-primary/40 transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                <span class="material-symbols-outlined text-3xl">music_note</span>
                            </div>
                            <span class="px-3 py-1 rounded-full bg-slate-500/20 text-slate-500 text-xs font-bold uppercase tracking-wider">
                                Inativo
                            </span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-display mb-1">
                            Lirael Vane
                        </h3>
                        <div class="flex flex-col gap-1 text-slate-500 dark:text-slate-400 text-sm mb-6">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">person</span>
                                <span>Tiefling • Bardo</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">military_tech</span>
                                <span class="font-bold text-primary">Nível 5</span>
                            </div>
                        </div>
                        <button class="mt-auto w-full py-2.5 rounded-lg bg-primary/10 text-primary text-sm font-bold hover:bg-primary hover:text-white transition-all">
                            Ver ficha do personagem
                        </button>
                    </div>

                    <div class="group flex flex-col p-6 rounded-xl border border-primary/10 bg-slate-50 dark:bg-primary/5 hover:border-primary/40 transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/10 text-primary">
                                <span class="material-symbols-outlined text-3xl">health_cross</span>
                            </div>
                            <span class="px-3 py-1 rounded-full bg-yellow-500/10 text-yellow-600 text-xs font-bold uppercase tracking-wider">
                                Favorito
                            </span>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-slate-100 font-display mb-1">
                            Brother Thomas
                        </h3>
                        <div class="flex flex-col gap-1 text-slate-500 dark:text-slate-400 text-sm mb-6">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">person</span>
                                <span>Humano • Clérigo</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-sm">military_tech</span>
                                <span class="font-bold text-primary">Nível 15</span>
                            </div>
                        </div>
                        <button class="mt-auto w-full py-2.5 rounded-lg bg-primary/10 text-primary text-sm font-bold hover:bg-primary hover:text-white transition-all">
                            Ver ficha do personagem
                        </button>
                    </div>

                    <div class="flex flex-col items-center justify-center p-6 rounded-xl border-2 border-dashed border-primary/20 bg-transparent hover:border-primary/40 transition-all cursor-pointer group">
                        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-primary/5 text-primary/40 group-hover:text-primary group-hover:bg-primary/10 transition-all mb-4">
                            <span class="material-symbols-outlined text-4xl">person_add</span>
                        </div>
                        <p class="text-slate-500 dark:text-slate-400 font-bold group-hover:text-primary transition-colors">
                            Começar uma nova jornada
                        </p>
                        <p class="text-slate-400 dark:text-slate-500 text-xs mt-1">
                            Adicione mais um herói a sua campanha.
                        </p>
                    </div>

                </div>
            </div>
        </main>
    </div>
</div>