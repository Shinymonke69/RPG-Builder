@model RpgBuilderMvc.Application.ViewModels.CharacterEditViewModel

<div id="tab-magias" class="mt-6">
    <div class="p-6 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent">
        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">auto_stories</span>
            Livro de magias
        </h3>

        <div class="space-y-2">
            @foreach (var cs in Model.CharacterSpells
                .OrderBy(cs => cs.Spell.Level)
                .ThenBy(cs => cs.Spell.Name))
            {
                <!-- card de cada magia -->
            }
        </div>
    </div>
</div>