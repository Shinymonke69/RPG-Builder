@model RpgBuilderMvc.Application.ViewModels.CharacterEditViewModel

@{
    ViewData["Title"] = "Editar Personagem";
}

@{
    var classes = ViewBag.Classes as List<RpgBuilderMvc.Domain.Entities.Class> ?? new();
    var races = ViewBag.Races as List<RpgBuilderMvc.Domain.Entities.Race> ?? new();
    var backgrounds = ViewBag.Backgrounds as List<RpgBuilderMvc.Domain.Entities.Background> ?? new();
}

<form asp-action="Edit" asp-controller="Characters" method="post">
    <input type="hidden" name="id" value="@Model.Character.Id" />
    <main class="flex-1 px-4 lg:px-40 py-8">
        <div class="layout-content-container flex flex-col max-w-[1024px] mx-auto gap-8">
            <!-- Character Hero Section -->
            <a asp-controller="Home" asp-action="Index" class="inline-flex items-center justify-center h-9 w-9 bg-white rounded-full border border-border-dark text-muted-dark hover:bg-surface-dark transition-colors">
                <span class="material-symbols-outlined text-base">arrow_back</span>
            </a>
            <div class="flex flex-col md:flex-row gap-6 items-center md:items-start p-6 rounded-xl bg-white border border-slate-200 dark:border-[#48232c] parchment-effect">
                <div class="flex flex-col flex-1 gap-2 text-center md:text-left">
                    <input name="name"
                        class="bg-transparent border-none text-3xl font-bold p-0 focus:ring-0 text-slate-900 dark:text-white"
                        type="text"
                        value="@Model.Character.Name" />
                    <div class="flex flex-wrap gap-x-4 gap-y-1 justify-center md:justify-start text-primary font-medium">
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">military_tech</span>
                            <span>Nível</span>
                            <input name="level"
                                type="number"
                                value="@Model.Character.Level"
                                min="1"
                                max="20"
                                class="w-16 bg-transparent border border-border-dark/40 rounded px-2 py-0.5 text-sm text-slate-900 dark:text-white focus:ring-1 focus:ring-primary focus:outline-none" />
                        </span>
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">person</span>
                            @Model.Character.RaceName
                        </span>
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">auto_fix_high</span>
                            @Model.Character.ClassName
                        </span>
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">history_edu</span>
                            @Model.Character.BackgroundName
                        </span>
                    </div>
                    <div class="mt-4 w-full max-w-sm">
                        <div class="flex justify-between text-xs mb-1 uppercase tracking-wider font-bold text-slate-500 dark:text-[#c992a0] items-baseline">
                            <span>Pontos de experiência</span>
                            <div class="flex items-baseline gap-1">
                                <input type="number" name="xp" value="@Model.Character.Xp" class="bg-transparent border-none p-0 text-right text-xs font-bold w-16 focus:ring-0 text-slate-900 dark:text-white" min="0" max="355000" />
                                <span id="max-xp-display">/ 0 XP</span>
                            </div>
                        </div>
                        <div class="h-2 w-full bg-slate-200 dark:bg-[#48232c] rounded-full overflow-hidden">
                            <div id="xp-bar" class="h-full bg-primary transition-all" style="width: 0%;"></div>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4 min-w-[200px]">
                    <div class="flex flex-col items-center justify-center p-3 bg-white dark:bg-primary/10 rounded-lg border border-primary/20">
                        <span class="text-xs uppercase font-bold text-primary">Classe de Armadura</span>
                        <span id="ac-value" class="text-2xl font-bold">13</span>
                    </div>
                    <div class="flex flex-col items-center justify-center p-3 bg-white dark:bg-primary/10 rounded-lg border border-primary/20">
                        <span class="text-xs uppercase font-bold text-primary">Iniciativa</span>
                        <span id="initiative-value" class="text-2xl font-bold">+2</span>
                    </div>
                </div>
            </div>

            <!-- Tabs Navigation -->
                <div class="border-b border-slate-200 dark:border-[#48232c]">
                <div class="flex gap-8 overflow-x-auto custom-scrollbar tabs-nav">
                    <a data-tab="tab-atributos" class="border-b-2 border-primary text-primary pb-4 font-bold whitespace-nowrap" href="#tab-atributos">Atributos principais</a>
                    <a data-tab="tab-magias" class="border-b-2 border-transparent text-slate-500 hover:text-primary pb-4 font-bold transition-colors whitespace-nowrap" href="#tab-magias">Livro de magias</a>
                    <a data-tab="tab-equipamento" class="border-b-2 border-transparent text-slate-500 hover:text-primary pb-4 font-bold transition-colors whitespace-nowrap" href="#tab-equipamento">Equipamento</a>
                </div>
            </div>

            <!-- Aqui entram as partials -->
            @await Html.PartialAsync("_TabBackground", Model)
            @await Html.PartialAsync("_TabSpells", Model)
            @await Html.PartialAsync("_TabEquipment", Model)

            <div class="mt-8 flex justify-end gap-7">
                <button class="px-10 py-3 rounded-lg bg-green-600 text-white font-bold hover:brightness-110 shadow-lg shadow-primary/20 transition-all" type="submit">
                    Salvar alterações
                </button>
            </div>
        </div>
        @section Scripts {
            <script>
                // ── Atributos no Edit (mesma lógica do Create) ─────────────
                document.querySelectorAll('.stat-input').forEach(input => {
                    input.addEventListener('input', function () {
                        let val = parseInt(this.value);
                        if (isNaN(val)) val = 8;
                        if (val < 8) { this.value = 8; val = 8; }
                        if (val > 20) { this.value = 20; val = 20; }

                        let mod = Math.floor((val - 10) / 2);
                        let modText = mod >= 0 ? "+" + mod : mod.toString();

                        let container = this.closest('.flex-col');
                        if (!container) return;

                        let modEl = container.querySelector('.stat-modifier');
                        if (modEl) modEl.innerText = modText;

                        let percent = Math.min(100, Math.max(0, (val * 100) / 20));
                        let bar = container.querySelector('.stat-bar');
                        if (bar) bar.style.width = percent + "%";

                        // Atualiza CA e Iniciativa ao alterar qualquer atributo (usa Destreza)
                        const dexInput = document.querySelector('input[name="dexterity"]');
                        if (dexInput) {
                            let dv = parseInt(dexInput.value);
                            if (isNaN(dv)) dv = 8;
                            let dexMod = Math.floor((dv - 10) / 2);

                            let ac = 10 + dexMod;
                            ac = Math.max(0, Math.min(100, ac));
                            const acEl = document.getElementById('ac-value');
                            if (acEl) acEl.innerText = ac;

                            let initiative = Math.max(-10, Math.min(100, dexMod));
                            const initEl = document.getElementById('initiative-value');
                            if (initEl) initEl.innerText = (initiative >= 0 ? "+" + initiative : initiative.toString());
                        }
                    });

                    input.addEventListener('change', function () {
                        let v = parseInt(this.value);
                        if (isNaN(v) || v < 8) {
                            this.value = 8;
                            this.dispatchEvent(new Event('input'));
                        } else if (v > 20) {
                            this.value = 20;
                            this.dispatchEvent(new Event('input'));
                        }
                    });
                });

                function getProficiencyBonus() {
                    const level = parseInt(document.querySelector('input[name="level"]').value) || 1;
                    return Math.ceil(level / 4) + 1;
                }

                function updateSkills() {
                    const profBonus = getProficiencyBonus();
                    
                    const abilities = {
                        'STR': parseInt(document.querySelector('input[name="strength"]').value) || 8,
                        'DEX': parseInt(document.querySelector('input[name="dexterity"]').value) || 8,
                        'CON': parseInt(document.querySelector('input[name="constitution"]').value) || 8,
                        'INT': parseInt(document.querySelector('input[name="intelligence"]').value) || 8,
                        'WIS': parseInt(document.querySelector('input[name="wisdom"]').value) || 8,
                        'CHA': parseInt(document.querySelector('input[name="charisma"]').value) || 8
                    };

                    const modifiers = {};
                    for (const [key, val] of Object.entries(abilities)) {
                        modifiers[key] = Math.floor((val - 10) / 2);
                    }

                    document.querySelectorAll('.skill-bonus').forEach(el => {
                        const ability = el.getAttribute('data-ability');
                        const cb = el.closest('label').querySelector('.skill-checkbox');
                        const isProficient = cb && cb.checked;
                        
                        let bonus = modifiers[ability] || 0;
                        if (isProficient) {
                            bonus += profBonus;
                        }

                        el.innerText = bonus >= 0 ? "+" + bonus : bonus.toString();
                    });

                    // Atualiza Classe de Armadura e Iniciativa
                    const dexMod = modifiers['DEX'] || 0;

                    // CA = 10 + modificador de Destreza, limitado entre 0 e 100
                    let ac = 10 + dexMod;
                    ac = Math.max(0, Math.min(100, ac));
                    const acEl = document.getElementById('ac-value');
                    if (acEl) acEl.innerText = ac;

                    // Iniciativa = modificador de Destreza, limitado entre -10 e 100
                    let initiative = dexMod;
                    initiative = Math.max(-10, Math.min(100, initiative));
                    const initEl = document.getElementById('initiative-value');
                    if (initEl) initEl.innerText = (initiative >= 0 ? "+" + initiative : initiative.toString());
                }

                function updateHP() {
                    const hitDiceMap = {
                        'barbarian': 12,
                        'bard': 8,
                        'warlock': 8,
                        'cleric': 8,
                        'druid': 8,
                        'sorcerer': 6,
                        'fighter': 10,
                        'rogue': 8,
                        'wizard': 6,
                        'monk': 8,
                        'paladin': 10,
                        'ranger': 10
                    };

                    const classSelect = document.querySelector('select[name="classIndex"]');
                    const classIndex = classSelect ? classSelect.value : '@Model.Character.ClassIndex';
                    
                    const level = parseInt(document.querySelector('input[name="level"]').value) || 1;
                    const con = parseInt(document.querySelector('input[name="constitution"]').value) || 10;
                    const conMod = Math.floor((con - 10) / 2);

                    const hitDie = hitDiceMap[classIndex] || 8;
                    const avgHitDie = Math.floor(hitDie / 2) + 1;

                    let maxHp = 0;
                    if (level >= 1) {
                        maxHp = (hitDie + conMod) + (level - 1) * Math.max(1, avgHitDie + conMod);
                    }

                    const maxHpEl = document.getElementById('max-hp-display');
                    if (maxHpEl) maxHpEl.innerText = '/ ' + maxHp;

                    const hdEl = document.getElementById('hit-dice-display');
                    if (hdEl) hdEl.innerText = level + 'd' + hitDie;

                    const currentHpInput = document.getElementById('current-hp-input');
                    if (currentHpInput) {
                        let currentHp = parseInt(currentHpInput.value);
                        if (isNaN(currentHp) || currentHp < 0) {
                            currentHp = 0;
                            currentHpInput.value = 0;
                        }
                        if (currentHp > maxHp) {
                            currentHp = maxHp;
                            currentHpInput.value = maxHp;
                        }

                        const hpBar = document.getElementById('hp-bar');
                        if (hpBar) {
                            const percent = maxHp > 0 ? (currentHp / maxHp) * 100 : 0;
                            hpBar.style.width = Math.min(100, Math.max(0, percent)) + '%';
                        }
                    }
                }

                const xpThresholds = [
                    0, 300, 900, 2700, 6500, 14000, 23000, 34000, 48000, 64000,
                    85000, 100000, 120000, 140000, 165000, 195000, 225000, 265000, 305000, 355000
                ];

                function updateXP() {
                    const xpInput = document.querySelector('input[name="xp"]');
                    const levelInput = document.querySelector('input[name="level"]');
                    if (!xpInput || !levelInput) return;

                    let xp = parseInt(xpInput.value);
                    if (isNaN(xp) || xp < 0) {
                        xp = 0;
                        xpInput.value = 0;
                    } else if (xp > 355000) {
                        xp = 355000;
                        xpInput.value = 355000;
                    }

                    // calculate level from XP
                    let newLevel = 1;
                    for (let i = xpThresholds.length - 1; i >= 0; i--) {
                        if (xp >= xpThresholds[i]) {
                            newLevel = i + 1;
                            break;
                        }
                    }

                    // if level changed due to XP, update the level input and trigger level changes
                    if (parseInt(levelInput.value) !== newLevel) {
                        levelInput.value = newLevel;
                        updateSkills();
                        updateHP();
                    }

                    const maxXP = newLevel < 20 ? xpThresholds[newLevel] : 355000;
                    const prevXP = newLevel > 1 ? xpThresholds[newLevel - 1] : 0;
                    
                    const maxXpEl = document.getElementById('max-xp-display');
                    if (maxXpEl) maxXpEl.innerText = `/ ${maxXP.toLocaleString('pt-BR')} XP`;

                    const xpBar = document.getElementById('xp-bar');
                    if (xpBar) {
                        let percent = 100;
                        if (newLevel < 20) {
                            percent = ((xp - prevXP) / (maxXP - prevXP)) * 100;
                        }
                        xpBar.style.width = Math.min(100, Math.max(0, percent)) + '%';
                    }
                }

                document.querySelector('input[name="level"]').addEventListener('change', function() {
                    let lvl = parseInt(this.value);
                    if (isNaN(lvl) || lvl < 1) { this.value = 1; lvl = 1; }
                    else if (lvl > 20) { this.value = 20; lvl = 20; }
                    
                    const xpInput = document.querySelector('input[name="xp"]');
                    if (!xpInput) return;

                    const currentXp = parseInt(xpInput.value) || 0;
                    
                    // If current XP doesn't match the level, set it to the minimum for that level
                    const minXp = xpThresholds[lvl - 1];
                    const maxXP = lvl < 20 ? xpThresholds[lvl] : 355000;
                    
                    if (currentXp < minXp || currentXp >= maxXP) {
                        xpInput.value = minXp;
                        updateXP();
                    }
                });

                // Attach events for dynamic updates
                document.querySelectorAll('.stat-input, input[name="level"]').forEach(input => {
                    input.addEventListener('input', () => {
                        updateSkills();
                        updateHP();
                    });
                });
                document.querySelectorAll('.skill-checkbox').forEach(cb => {
                    cb.addEventListener('change', updateSkills);
                });
                const classSelect = document.querySelector('select[name="classIndex"]');
                if (classSelect) {
                    classSelect.addEventListener('change', updateHP);
                }
                const currentHpInput = document.getElementById('current-hp-input');
                if (currentHpInput) {
                    currentHpInput.addEventListener('input', updateHP);
                }
                const xpInput = document.querySelector('input[name="xp"]');
                if (xpInput) {
                    xpInput.addEventListener('input', updateXP);
                }

                // inicializa os modificadores/barras com os valores atuais
                document.querySelectorAll('.stat-input').forEach(input => {
                    input.dispatchEvent(new Event('input'));
                });
                updateSkills();
                updateHP();
                updateXP();

                // Tabs: controla exibição e estilo ativo entre as seções
                function initTabs() {
                    const tabLinks = document.querySelectorAll('.tabs-nav a[data-tab]');
                    const tabIds = Array.from(tabLinks).map(l => l.getAttribute('data-tab')).filter(Boolean);

                    function setActive(targetId) {
                        tabLinks.forEach(link => {
                            const id = link.getAttribute('data-tab');
                            if (id === targetId) {
                                link.classList.add('border-primary', 'text-primary');
                                link.classList.remove('border-transparent', 'text-slate-500');
                            } else {
                                link.classList.remove('border-primary', 'text-primary');
                                link.classList.add('border-transparent', 'text-slate-500');
                            }
                        });

                        tabIds.forEach(id => {
                            const el = document.getElementById(id);
                            if (!el) return;
                            el.style.display = (id === targetId) ? '' : 'none';
                        });
                    }

                    tabLinks.forEach(link => {
                        link.addEventListener('click', function (e) {
                            e.preventDefault();
                            const id = this.getAttribute('data-tab');
                            if (!id) return;
                            setActive(id);
                            try { history.replaceState(null, '', '#' + id); } catch (ex) { }
                        });
                    });

                    let initial = location.hash ? location.hash.replace('#', '') : (tabIds[0] || 'tab-atributos');
                    if (!tabIds.includes(initial)) initial = tabIds[0] || 'tab-atributos';
                    setActive(initial);
                }

                initTabs();

                // ── Aviso de saída sem salvar ─────────────────────
                (function () {
                    const form = document.querySelector('form[asp-action="Edit"][asp-controller="Characters"]')
                            || document.querySelector('form');

                    if (!form) return;

                    let isDirty = false;

                    form.addEventListener('input', () => { isDirty = true; });
                    form.addEventListener('change', () => { isDirty = true; });

                    form.addEventListener('submit', () => {
                        isDirty = false;
                        window.onbeforeunload = null;
                    });

                    window.onbeforeunload = function (e) {
                        if (!isDirty) return;

                        e.preventDefault();
                        e.returnValue = '';
                        return '';
                    };
                })();
            </script>
        }
    </main>
</form>
