@{
    ViewData["Title"] = "Painel";
}

<div class="layout-container flex h-full grow flex-col">
    <div class="flex flex-1 flex-col">
        <main class="flex-1 p-6 md:p-10 w-full">
            <div class="max-w-6xl mx-auto">

                <div class="flex flex-wrap justify-between items-end gap-6 mb-8">
                    <div class="flex flex-col gap-2">
                        <h2 class="text-slate-900 dark:text-slate-100 text-4xl font-black leading-tight tracking-tight font-display">
                            Meus Personagens
                        </h2>
                        <p class="text-slate-500 dark:text-slate-400 text-lg">
                            Gerencie seus personagens.
                        </p>
                    </div>
                    <a asp-controller="Characters"
                       asp-action="Create"
                       class="flex items-center justify-center gap-2 rounded-lg h-12 px-6 bg-primary text-white text-sm font-bold tracking-wide hover:brightness-110 transition-all shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined">add</span>
                        <span>Criar novo personagem</span>
                    </a>
                </div>

                <div class="flex gap-3 mb-8 overflow-x-auto pb-2">
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-primary/20 px-5 text-primary text-sm font-bold">
                        Todos
                    </button>
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-slate-200 dark:bg-primary/5 px-5 text-slate-600 dark:text-slate-300 text-sm font-medium hover:bg-primary/10">
                        Ativos
                    </button>
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-slate-200 dark:bg-primary/5 px-5 text-slate-600 dark:text-slate-300 text-sm font-medium hover:bg-primary/10">
                        Arquivados
                    </button>
                    <button class="flex h-9 shrink-0 items-center justify-center rounded-full bg-slate-200 dark:bg-primary/5 px-5 text-slate-600 dark:text-slate-300 text-sm font-medium hover:bg-primary/10">
                        Favoritos
                    </button>
                </div>

                <div class="mt-8 rounded-2xl bg-blue-550/80 dark:bg-blue-550/70 border border-blue-550/70 shadow-xl p-6 md:p-8">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

                        <!-- Cards estáticos por enquanto (depois viram @foreach) -->
                        <!-- Thaelin Silverleaf -->
                        <!-- ... (mantém o HTML desse card) ... -->

                        <!-- Grog Strongjaw -->
                        <!-- ... -->

                        <!-- Lirael Vane -->
                        <!-- ... -->

                        <!-- Brother Thomas -->
                        <!-- ... -->

                    </div>
                </div>
            </div>
        </main>
    </div>
</div>