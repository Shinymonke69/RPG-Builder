@model RpgBuilderMvc.Application.ViewModels.CharacterEditViewModel

<div id="tab-equipamento">
    <div class="p-4 md:p-6 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent">
        <h3 class="text-3xl font-bold mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-3xl">inventory_2</span>
            Equipamento
        </h3>

        <div class="space-y-8">
            
            <div>
                <h4 class="text-2xl font-bold mb-4 text-slate-800 dark:text-slate-200 border-b border-border-dark pb-2">Armas</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-96 overflow-y-auto pr-2 custom-scrollbar">
                    @foreach (var w in Model.AllWeapons)
                    {
                        var isEquipped = Model.CharacterWeapons.Any(cw => cw.WeaponId == w.Id);
                        <label class="flex items-start gap-4 p-4 rounded-xl border border-border-dark bg-surface-dark cursor-pointer group hover:border-primary/40 transition-all">
                            <input type="checkbox" name="selectedWeapons" value="@w.Id" class="mt-1 w-5 h-5 text-primary bg-background border-border-dark rounded focus:ring-primary" @(isEquipped ? "checked" : "") />
                            <div class="flex flex-col flex-1">
                                <span class="font-bold text-lg text-slate-900 dark:text-slate-100">@w.Name</span>
                                <div class="text-sm font-medium mt-2 flex flex-wrap gap-x-3 gap-y-2">
                                    @if (!string.IsNullOrWhiteSpace(w.Damage)) { <span class="bg-red-500/10 text-red-700 dark:text-red-400 px-2 py-1 rounded flex items-center gap-1"><span class="material-symbols-outlined text-base">swords</span> @w.Damage</span> }
                                    @if (!string.IsNullOrWhiteSpace(w.Price)) { <span class="bg-yellow-500/10 text-yellow-700 dark:text-yellow-400 px-2 py-1 rounded flex items-center gap-1"><span class="material-symbols-outlined text-base">monetization_on</span> @w.Price</span> }
                                    @if (!string.IsNullOrWhiteSpace(w.Weight)) { <span class="bg-slate-500/10 text-slate-600 dark:text-slate-300 px-2 py-1 rounded flex items-center gap-1"><span class="material-symbols-outlined text-base">weight</span> @w.Weight</span> }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(w.Properties)) {
                                    <span class="text-sm text-slate-900 dark:text-slate-100 mt-2 font-normal">@w.Properties</span>
                                }
                            </div>
                        </label>
                    }
                </div>
            </div>

            
            <div>
                <h4 class="text-2xl font-bold mb-4 text-slate-800 dark:text-slate-200 border-b border-border-dark pb-2">Armaduras e Escudos</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-96 overflow-y-auto pr-2 custom-scrollbar">
                    @foreach (var a in Model.AllArmors)
                    {
                        var isEquipped = Model.CharacterArmors.Any(ca => ca.ArmorId == a.Id);
                        <label class="flex items-start gap-4 p-4 rounded-xl border border-border-dark bg-surface-dark cursor-pointer group hover:border-primary/40 transition-all">
                            <input type="checkbox" name="selectedArmors" value="@a.Id" class="mt-1 w-5 h-5 text-primary bg-background border-border-dark rounded focus:ring-primary" @(isEquipped ? "checked" : "") />
                            <div class="flex flex-col flex-1">
                                <span class="font-bold text-lg text-slate-900 dark:text-slate-100">@a.Name</span>
                                <div class="text-sm font-medium mt-2 flex flex-wrap gap-x-3 gap-y-2">
                                    @if (!string.IsNullOrWhiteSpace(a.Ac)) { <span class="bg-blue-500/10 text-blue-700 dark:text-blue-400 px-2 py-1 rounded flex items-center gap-1"><span class="material-symbols-outlined text-base">shield</span> @a.Ac</span> }
                                    @if (!string.IsNullOrWhiteSpace(a.Price)) { <span class="bg-yellow-500/10 text-yellow-700 dark:text-yellow-400 px-2 py-1 rounded flex items-center gap-1"><span class="material-symbols-outlined text-base">monetization_on</span> @a.Price</span> }
                                    @if (!string.IsNullOrWhiteSpace(a.Weight)) { <span class="bg-slate-500/10 text-slate-600 dark:text-slate-300 px-2 py-1 rounded flex items-center gap-1"><span class="material-symbols-outlined text-base">weight</span> @a.Weight</span> }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(a.Stealth) || !string.IsNullOrWhiteSpace(a.Strength)) {
                                    <div class="text-sm text-slate-600 dark:text-slate-400 mt-2 font-normal flex flex-wrap gap-3">
                                        @if (!string.IsNullOrWhiteSpace(a.Strength)) { <span>Força Min: @a.Strength</span> }
                                        @if (!string.IsNullOrWhiteSpace(a.Stealth)) { <span>Furtividade: @a.Stealth</span> }
                                    </div>
                                }
                            </div>
                        </label>
                    }
                </div>
            </div>

            
            <div>
                <h4 class="text-2xl font-bold mb-4 text-slate-800 dark:text-slate-200 border-b border-border-dark pb-2">Inventário Geral</h4>
                <div class="p-3 bg-white dark:bg-background border border-border-dark rounded-xl">
                    <textarea name="equipmentNotes" id="equipment-list" rows="10" placeholder="Anotações de equipamentos, mochilas, poções, ouro..." class="w-full bg-transparent border-none p-3 text-base whitespace-pre-wrap leading-relaxed focus:ring-0 resize-y text-slate-800 dark:text-slate-200">@Model.Character.EquipmentNotes</textarea>
                </div>
            </div>
        </div>
    </div>
</div>
