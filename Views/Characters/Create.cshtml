@{
    ViewData["Title"] = "Novo Personagem";
}
@{
    var classes = ViewBag.Classes as List<RpgBuilderMvc.Domain.Entities.Class> ?? new();
    var races = ViewBag.Races as List<RpgBuilderMvc.Domain.Entities.Race> ?? new();
    var backgrounds = ViewBag.Backgrounds as List<RpgBuilderMvc.Domain.Entities.Background> ?? new();
    var randomCharacter = ViewBag.RandomCharacter as RpgBuilderMvc.Domain.Entities.Character;
    string backgroundTraitsText = ViewBag.BackgroundTraitsText as string ?? "";
}

<form asp-action="Create" asp-controller="Characters" method="post">
    <main class="flex-1 px-4 md:px-20 py-8 max-w-6xl mx-auto w-full">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-10">
            <div class="flex flex-col gap-2">
                <a asp-controller="Home" asp-action="Index"
                class="inline-flex items-center justify-center h-9 w-9 rounded-full bg-white border border-border-dark text-muted-dark hover:bg-surface-dark transition-colors">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                </a>
                <h1 class="text-5xl font-black tracking-tight">Novo Personagem</h1>
                <p class="text-muted-dark text-lg">Aproveite o poder da aleatoriedade e crie o seu próprio personagem.</p>
            </div>
            <a asp-controller="Characters"
            asp-action="GenerateRandom"
            class="flex min-w-[240px] cursor-pointer items-center justify-center rounded-xl h-14 px-8 bg-primary hover:bg-primary/90 text-white gap-3 text-lg font-bold transition-all shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined">auto_fix_high</span>
                <span>Gerar personagem aleatório</span>
            </a>
        </div>

        <div class="mt-8 rounded-2xl bg-blue-550/80 dark:bg-blue-550/70 border border-blue-550/70 shadow-xl p-6 md:p-8">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-1 flex flex-col gap-6">
                    <div class="rounded-xl bg-white bg-surface-dark border border-border-dark p-6">

                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-muted-dark mb-1 ml-1">Nome do herói</label>
                                <input name="name"
                                    class="w-full bg-background border border-border-dark rounded-lg px-4 py-3 text-slate focus:ring-2 focus:ring-primary focus:outline-none"
                                    type="text"
                                    value="@(randomCharacter?.Name ?? ViewBag.RandomName)" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-muted-dark mb-1 ml-1">Classe</label>
                                <select name="classIndex"
                                        class="w-full bg-background border border-border-dark rounded-lg px-4 py-3 text-slate focus:ring-2 focus:ring-primary focus:outline-none">
                                    @{
                                        var defaultClass = randomCharacter != null ? randomCharacter.ClassIndex : (string)ViewBag.RandomClass;
                                    }
                                    @foreach (var c in classes)
                                    {
                                        <option value="@c.Index" selected="@(c.Index == defaultClass)">@c.Name</option>
                                    }
                                </select>

                                <label class="block text-sm font-medium text-muted-dark mb-1 ml-1 mt-4">Raça</label>
                                <select name="raceIndex" class="w-full bg-background border border-border-dark rounded-lg px-4 py-3 text-slate focus:ring-2 focus:ring-primary focus:outline-none">
                                    @{
                                        var defaultRace = randomCharacter != null ? randomCharacter.RaceIndex : (string)ViewBag.RandomRace;
                                    }
                                    @foreach (var r in races)
                                    {
                                        <option value="@r.Index" selected="@(r.Index == defaultRace)">@r.Name</option>
                                    }
                                </select>

                                <label class="block text-sm font-medium text-muted-dark mb-1 ml-1 mt-4">Antecedente</label>
                                <select id="backgroundSelect" name="backgroundIndex" class="w-full bg-background border border-border-dark rounded-lg px-4 py-3 text-slate focus:ring-2 focus:ring-primary focus:outline-none">
                                    @{
                                        var defaultBg = randomCharacter != null ? randomCharacter.BackgroundIndex : (string)ViewBag.RandomBackground;
                                    }
                                    @foreach (var b in backgrounds)
                                    {
                                        <option value="@b.Index" selected="@(b.Index == defaultBg)">@b.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-2 space-y-8">
                    <div>
                        <div class="flex items-center gap-3 mb-6">
                            <span class="material-symbols-outlined text-primary">analytics</span>
                            <h2 class="text-2xl font-bold">Atributos</h2>
                        </div>
                        @{
                            var stats = new[] {
                                new { Name = "Força", Key = "strength", Value = randomCharacter?.Strength ?? ViewBag.DefaultStats[0] },
                                new { Name = "Destreza", Key = "dexterity", Value = randomCharacter?.Dexterity ?? ViewBag.DefaultStats[1] },
                                new { Name = "Constituição", Key = "constitution", Value = randomCharacter?.Constitution ?? ViewBag.DefaultStats[2] },
                                new { Name = "Inteligência", Key = "intelligence", Value = randomCharacter?.Intelligence ?? ViewBag.DefaultStats[3] },
                                new { Name = "Sabedoria", Key = "wisdom", Value = randomCharacter?.Wisdom ?? ViewBag.DefaultStats[4] },
                                new { Name = "Carisma", Key = "charisma", Value = randomCharacter?.Charisma ?? ViewBag.DefaultStats[5] }
                            };
                        }
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            @foreach(var stat in stats) {
                                int val = stat.Value;
                                int mod = (int)Math.Floor((val - 10) / 2.0);
                                string modText = mod >= 0 ? $"+{mod}" : mod.ToString();
                                int percent = Math.Min(100, Math.Max(0, (val * 100) / 20));

                                <div class="flex flex-col p-4 rounded-xl bg-white bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">@stat.Name</span>
                                        <span class="text-primary text-xs font-bold stat-modifier">@modText</span>
                                    </div>
                                    <input name="@stat.Key"
                                        class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0 stat-input"
                                        type="number"
                                        min="8"
                                        max="20"
                                        value="@val" />
                                    <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                        <div class="h-full bg-primary stat-bar transition-all" style="width: @(percent)%;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">history_edu</span>
                                Personalidade &amp; História
                            </h3>
                            <div class="space-y-4" id="traits-container">
                                <div class="p-3 bg-white border border-border-dark rounded-lg">
                                    <span class="text-[10px] font-bold text-primary uppercase">Traços de Personalidade</span>
                                    <textarea name="personalityTraits" id="bg-personality" rows="3" class="w-full bg-transparent border-none p-0 text-sm whitespace-pre-wrap leading-relaxed focus:ring-0 resize-y"></textarea>
                                </div>
                                <div class="p-3 bg-white border border-border-dark rounded-lg">
                                    <span class="text-[10px] font-bold text-primary uppercase">Ideais</span>
                                    <textarea name="ideals" id="bg-ideals" rows="2" class="w-full bg-transparent border-none p-0 text-sm whitespace-pre-wrap leading-relaxed focus:ring-0 resize-y"></textarea>
                                </div>
                                <div class="p-3 bg-white border border-border-dark rounded-lg">
                                    <span class="text-[10px] font-bold text-primary uppercase">Laços</span>
                                    <textarea name="bonds" id="bg-bonds" rows="2" class="w-full bg-transparent border-none p-0 text-sm whitespace-pre-wrap leading-relaxed focus:ring-0 resize-y"></textarea>
                                </div>
                                <div class="p-3 bg-white border border-border-dark rounded-lg">
                                    <span class="text-[10px] font-bold text-primary uppercase">Defeitos</span>
                                    <textarea name="flaws" id="bg-flaws" rows="2" class="w-full bg-transparent border-none p-0 text-sm whitespace-pre-wrap leading-relaxed focus:ring-0 resize-y"></textarea>
                                </div>
                            </div>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary">inventory_2</span>
                                Equipamento inicial
                            </h3>
                            <div class="p-3 bg-white border border-border-dark rounded-lg">
                                <textarea name="equipmentNotes" id="equipment-list" rows="5" class="w-full bg-transparent border-none p-0 text-sm whitespace-pre-wrap leading-relaxed focus:ring-0 resize-y"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="pt-6 flex justify-end gap-4">
                        <button type="submit"
                                name="mode"
                                value="manual"
                                class="px-10 py-3 rounded-lg bg-primary text-white font-bold hover:brightness-110 shadow-lg shadow-primary/20 transition-all">
                            Finalizar herói
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</form>

@section Scripts {
    <script>
        // ── Atributos ──────────────────────────────────────────
        document.querySelectorAll('.stat-input').forEach(input => {
            input.addEventListener('input', function() {
                let val = parseInt(this.value);
                if (isNaN(val)) return;

                let mod = Math.floor((val - 10) / 2);
                let modText = mod >= 0 ? "+" + mod : mod.toString();

                let container = this.closest('.flex-col');
                container.querySelector('.stat-modifier').innerText = modText;

                let percent = Math.min(100, Math.max(0, (val * 100) / 20));
                container.querySelector('.stat-bar').style.width = percent + "%";
            });

            input.addEventListener('change', function() {
                if (parseInt(this.value) < 8 || isNaN(parseInt(this.value))) {
                    this.value = 8;
                } else if (parseInt(this.value) > 20) {
                    this.value = 20;
                }
                this.dispatchEvent(new Event('input'));
            });
        });

        // ── Traços do antecedente ────
        @{
            var bgJson = System.Text.Json.JsonSerializer.Serialize(backgrounds);
        }
        const backgroundsData = @Html.Raw(bgJson);

                // ── Equipamento inicial por classe ─────────────────────
        @{
            var classEquipDict = new Dictionary<string, string>();
            foreach (var c in classes)
            {
                classEquipDict[c.Index] = c.StartingEquipment ?? "";
            }
            var classEquipJson = System.Text.Json.JsonSerializer.Serialize(classEquipDict);
        }
        const classEquipmentData = @Html.Raw(classEquipJson);

        function updateTraits(index) {
            const bg = backgroundsData.find(b => b.Index === index);
            if (bg) {
                const elPers = document.getElementById('bg-personality');
                if (elPers) elPers.value = bg.PersonalityTraits || '';

                const elIdeals = document.getElementById('bg-ideals');
                if (elIdeals) elIdeals.value = bg.Ideals || '';

                const elBonds = document.getElementById('bg-bonds');
                if (elBonds) elBonds.value = bg.Bonds || '';

                const elFlaws = document.getElementById('bg-flaws');
                if (elFlaws) elFlaws.value = bg.Flaws || '';
            }
        }

        const bgSelect = document.getElementById('backgroundSelect');
        bgSelect.addEventListener('change', function() {
            updateTraits(this.value);
        });

        updateTraits(bgSelect.value);

        // ── Equipamento inicial da classe
        const classSelect = document.querySelector('select[name="classIndex"]');
        if (classSelect) {
            classSelect.addEventListener("change", function () {
                updateEquipment(this.value);
            });

            updateEquipment(classSelect.value);
        }

        function updateEquipment(classIndex) {
            const data = classEquipmentData[classIndex] || "";
            const listEl = document.getElementById("equipment-list");

            if (!listEl) return;

            if (!data) {
                listEl.value = "Nenhum equipamento inicial configurado para esta classe.";
                return;
            }

            listEl.value = data;
        }
    </script>
}

