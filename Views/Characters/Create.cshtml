@{
    ViewData["Title"] = "Novo Personagem";
}

<main class="flex-1 px-4 md:px-20 py-8 max-w-6xl mx-auto w-full">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-10">
        <div class="flex flex-col gap-2">
            <h1 class="text-5xl font-black tracking-tight">Novo Personagem</h1>
            <p class="text-muted-dark text-lg">Aproveite o poder da aleatoriedade e crie o seu próprio personagem.</p>
        </div>
        <button class="flex min-w-[240px] cursor-pointer items-center justify-center rounded-xl h-14 px-8 bg-primary hover:bg-primary/90 text-white gap-3 text-lg font-bold transition-all shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined">auto_fix_high</span>
            <span>Gerar personagem aleatório</span>
        </button>
    </div>

    <div class="mt-8 rounded-2xl bg-blue-550/80 dark:bg-blue-550/70 border border-blue-550/70 shadow-xl p-6 md:p-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-1 flex flex-col gap-6">
                <div class="rounded-xl bg-surface-dark border border-border-dark p-6">
                    <!-- Antique Altarpiece Frame -->
                    <div class="altarpiece-frame relative w-full aspect-[3/4] rounded-t-full p-4 mb-6 border-4 border-wood-light flex flex-col">
                        <div class="absolute top-2 left-1/2 -translate-x-1/2 flex gap-4">
                            <div class="carved-detail"></div>
                            <div class="carved-detail"></div>
                            <div class="carved-detail"></div>
                        </div>
                        <div class="relative flex-1 rounded-t-full overflow-hidden bg-black border-2 border-wood-dark shadow-inner">
                            <img class="w-full h-full object-cover opacity-90" data-alt="Illustration of a dark fantasy knight in armor" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB_vceQfwA7WcZnt_p8Iq0BAcc96XyfXV2s9uxMTigDNBJFHW4tssZFdhfsaeCcvHJDgkFBYsScg6D0oaUZRVdTSEh15VRQ8l9Wj-r7Fa7N4GKvoVQI2Z2sYTIjtvYSa56xxFOnMDwR6zYuDwO8xth9NkJjrp2sJJk1-d1286zYZL4tOhpKvJyMjHoBNiSNAi-X7JdimF4VGTDEPG-FMb83c61ELHSe1t7uQnWy_juGVPSPihIA7ktfQjBLdE7IQkDrNjKEryBgHv8"/>
                            <div class="parchment-overlay absolute inset-0"></div>
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/20"></div>
                            <button class="absolute bottom-4 right-4 bg-primary text-white p-2 rounded-full shadow-lg z-10 hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined">photo_camera</span>
                            </button>
                        </div>
                        <div class="mt-3 flex justify-between px-2">
                            <div class="carved-detail scale-75"></div>
                            <div class="carved-detail scale-75"></div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-muted-dark mb-1 ml-1">Nome do herói</label>
                            <input class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-slate-100 focus:ring-2 focus:ring-primary focus:outline-none" type="text" value="Aethelgard, o Bravo"/>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-muted-dark mb-1 ml-1">Classe &amp; Origem</label>
                            <select class="w-full bg-background-dark border border-border-dark rounded-lg px-4 py-3 text-slate-100 focus:ring-2 focus:ring-primary focus:outline-none">
                                <option>Cavaleiro Místico - Picos de Ferro</option>
                                <option>Ladino das Sombras - Floresta Sussurrante</option>
                                <option>Feiticeiro das Chamas - Ilhas das Brasas</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-2 space-y-8">
                <div>
                    <div class="flex items-center gap-3 mb-6">
                        <span class="material-symbols-outlined text-primary">analytics</span>
                        <h2 class="text-2xl font-bold">Atributos</h2>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                        <div class="flex flex-col p-4 rounded-xl bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">Força</span>
                                <span class="text-primary text-xs font-bold">+3</span>
                            </div>
                            <input class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0" type="number" value="16"/>
                            <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                <div class="h-full bg-primary w-4/5"></div>
                            </div>
                        </div>

                        <div class="flex flex-col p-4 rounded-xl bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">Destreza</span>
                                <span class="text-primary text-xs font-bold">+3</span>
                            </div>
                            <input class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0" type="number" value="16"/>
                            <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                <div class="h-full bg-primary w-4/5"></div>
                            </div>
                        </div>

                        <div class="flex flex-col p-4 rounded-xl bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">Constituição</span>
                                <span class="text-primary text-xs font-bold">+3</span>
                            </div>
                            <input class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0" type="number" value="16"/>
                            <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                <div class="h-full bg-primary w-4/5"></div>
                            </div>
                        </div>

                        <div class="flex flex-col p-4 rounded-xl bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">Inteligência</span>
                                <span class="text-primary text-xs font-bold">+3</span>
                            </div>
                            <input class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0" type="number" value="16"/>
                            <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                <div class="h-full bg-primary w-4/5"></div>
                            </div>
                        </div>

                        <div class="flex flex-col p-4 rounded-xl bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">Sabedoria</span>
                                <span class="text-primary text-xs font-bold">+3</span>
                            </div>
                            <input class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0" type="number" value="16"/>
                            <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                <div class="h-full bg-primary w-4/5"></div>
                            </div>
                        </div>

                        <div class="flex flex-col p-4 rounded-xl bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">Carisma</span>
                                <span class="text-primary text-xs font-bold">+3</span>
                            </div>
                            <input class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0" type="number" value="16"/>
                            <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                <div class="h-full bg-primary w-4/5"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">history_edu</span>
                            Traços &amp; habilidades
                        </h3>
                        <div class="space-y-3">
                            <div class="p-3 bg-surface-dark/50 border border-border-dark rounded-lg flex gap-3">
                                <span class="material-symbols-outlined text-primary">shield</span>
                                <div>
                                    <p class="font-bold text-sm">Treinamento em armadura pesada</p>
                                    <p class="text-xs text-muted-dark">Proficiência com todos os tipos de armadura pesada.</p>
                                </div>
                            </div>
                            <div class="p-3 bg-surface-dark/50 border border-border-dark rounded-lg flex gap-3">
                                <span class="material-symbols-outlined text-primary">auto_awesome</span>
                                <div>
                                    <p class="font-bold text-sm">Golpe Arcano</p>
                                    <p class="text-xs text-muted-dark">Imbui ataques com arma com 1d4 de dano de força.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">inventory_2</span>
                            Equipamento inicial
                        </h3>
                        <ul class="space-y-2">
                            <li class="flex items-center justify-between p-2 border-b border-border-dark/30">
                                <span class="text-sm">Espada grande desgastada</span>
                                <span class="text-xs text-muted-dark">6 lb</span>
                            </li>
                            <li class="flex items-center justify-between p-2 border-b border-border-dark/30">
                                <span class="text-sm">Peitoral de Ferro</span>
                                <span class="text-xs text-muted-dark">45 lb</span>
                            </li>
                            <li class="flex items-center justify-between p-2 border-b border-border-dark/30">
                                <span class="text-sm">Poção de cura (pequena)</span>
                                <span class="text-xs text-muted-dark">0,5 lb</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="pt-6 flex justify-end gap-4">
                    <button class="px-6 py-3 rounded-lg border border-border-dark text-muted-dark font-bold hover:bg-surface-dark transition-colors">
                        Redefinir alterações
                    </button>
                    <button class="px-10 py-3 rounded-lg bg-primary text-white font-bold hover:brightness-110 shadow-lg shadow-primary/20 transition-all">
                        Finalizar herói
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>

