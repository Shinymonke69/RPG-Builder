@model RpgBuilderMvc.Application.ViewModels.CharacterEditViewModel

<main class="layout-content-container flex flex-col max-w-[1024px] mx-auto gap-8">
    <div id="tab-atributos">
        <div class="mt-0 grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div>
                <label class="block text-sm font-medium text-muted-dark mb-1 ml-1">Classe</label>
                <select name="classIndex"
                        class="w-full bg-background border border-border-dark rounded-lg px-4 py-3 text-slate focus:ring-2 focus:ring-primary focus:outline-none">
                    @foreach (var c in Model.Classes)
                    {
                        <option value="@c.Index" selected="@(c.Index == Model.Character.ClassIndex)">@c.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-muted-dark mb-1 ml-1">Raça</label>
                <select name="raceIndex"
                        class="w-full bg-background border border-border-dark rounded-lg px-4 py-3 text-slate focus:ring-2 focus:ring-primary focus:outline-none">
                    @foreach (var r in Model.Races)
                    {
                        <option value="@r.Index" selected="@(r.Index == Model.Character.RaceIndex)">@r.Name</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-muted-dark mb-1 ml-1">Antecedente</label>
                <select name="backgroundIndex"
                        class="w-full bg-background border border-border-dark rounded-lg px-4 py-3 text-slate focus:ring-2 focus:ring-primary focus:outline-none">
                    @foreach (var b in Model.Backgrounds)
                    {
                        <option value="@b.Index" selected="@(b.Index == Model.Character.BackgroundIndex)">@b.Name</option>
                    }
                </select>
            </div>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Column: Abilities & Health -->
            <div class="lg:col-span-4 flex flex-col gap-6">
                <!-- Ability Scores -->
                @{
                    var stats = new[]
                    {
                        new { Name = "Força",        Key = "strength",     Value = Model.Character.Strength },
                        new { Name = "Destreza",     Key = "dexterity",    Value = Model.Character.Dexterity },
                        new { Name = "Constituição", Key = "constitution", Value = Model.Character.Constitution },
                        new { Name = "Inteligência", Key = "intelligence", Value = Model.Character.Intelligence },
                        new { Name = "Sabedoria",    Key = "wisdom",       Value = Model.Character.Wisdom },
                        new { Name = "Carisma",      Key = "charisma",     Value = Model.Character.Charisma }
                    };
                }
                <div class="grid grid-cols-2 gap-3">
                    @foreach (var stat in stats)
                    {
                        int val = stat.Value;
                        int mod = (int)Math.Floor((val - 10) / 2.0);
                        string modText = mod >= 0 ? $"+{mod}" : mod.ToString();
                        int percent = Math.Min(100, Math.Max(0, (val * 100) / 20));

                        <div class="flex flex-col p-4 rounded-xl bg-surface-dark border border-border-dark group hover:border-primary/50 transition-colors">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-muted-dark uppercase tracking-widest">@stat.Name</span>
                                <span class="text-primary text-xs font-bold stat-modifier">@modText</span>
                            </div>
                            <input name="@stat.Key"
                                class="w-full bg-transparent border-none p-0 text-3xl font-bold text-muted-dark focus:ring-0 stat-input"
                                type="number"
                                min="8"
                                value="@val" />
                            <div class="w-full h-1 bg-background-dark mt-3 rounded-full overflow-hidden">
                                <div class="h-full bg-primary stat-bar transition-all" style="width: @(percent)%;"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Vital Stats -->
                <div class="p-6 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent flex flex-col gap-4">
                    <div class="flex justify-between items-end">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-primary">PONTOS DE VIDA</span>
                            <div class="flex items-baseline gap-1">
                                <input class="bg-transparent border-none text-3xl font-bold p-0 w-12 focus:ring-0" type="text" value="28"/>
                                <span class="text-slate-400">/ 36</span>
                            </div>
                        </div>
                        <span class="material-symbols-outlined text-primary text-4xl">favorite</span>
                    </div>
                    <div class="h-3 w-full bg-slate-200 dark:bg-[#48232c] rounded-full overflow-hidden">
                        <div class="h-full bg-primary" style="width: 77%;"></div>
                    </div>
                    <div class="grid grid-cols-2 gap-4 mt-2">
                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold text-slate-500 dark:text-[#c992a0] uppercase">PV temporários</span>
                            <input class="bg-slate-100 dark:bg-[#34181f] border-none rounded p-1 text-sm focus:ring-1 focus:ring-primary" type="text" value="5"/>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold text-slate-500 dark:text-[#c992a0] uppercase">Dados de vida</span>
                            <div class="text-sm font-bold">5d6</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Skills, Inventory, Backstory -->
            <div class="lg:col-span-8 flex flex-col gap-6">
                <!-- Skills List (Scrollable) -->
                <div class="p-6 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent mt-6">
                    <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">list_alt</span>
                        Perícias &amp; proficiências
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2">
                        @foreach (var cs in Model.CharacterSkills.OrderBy(cs => cs.Skill.Name))
                        {
                            <div class="flex items-center justify-between py-1 border-b border-slate-100 dark:border-[#48232c]">
                                <div class="flex items-center gap-2">
                                    @if (cs.IsProficient || cs.IsExpert)
                                    {
                                        <span class="material-symbols-outlined text-[16px] text-primary" style="font-variation-settings: 'FILL' 1">check_circle</span>
                                        <span class="text-sm font-bold">@cs.Skill.Name</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-[16px] text-primary">circle</span>
                                        <span class="text-sm">@cs.Skill.Name</span>
                                    }
                                </div>
                                <span class="text-sm font-bold @(cs.IsProficient || cs.IsExpert ? "text-primary" : "")">
                                    @(cs.Bonus >= 0 ? "+" + cs.Bonus : cs.Bonus.ToString())
                                </span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Backstory & Personality -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="p-6 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent">
                        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">history_edu</span>
                            História
                        </h3>
                        <textarea name="story"
                            class="w-full bg-transparent border-none p-0 text-sm leading-relaxed resize-none focus:ring-0 custom-scrollbar h-32"
                            placeholder="Escreva aqui a história de origem do seu personagem...">@Model.Character.Story</textarea>
                    </div>
                    <div class="flex flex-col gap-4">
                        <div class="p-4 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent">
                            <span class="text-[10px] font-bold text-primary uppercase">Traços de personalidade</span>
                            <textarea name="personalityTraits"
                                    class="mt-1 w-full bg-transparent border-none p-0 text-sm leading-relaxed resize-none focus:ring-0 custom-scrollbar h-16"
                                    placeholder="Descreva aqui os traços de personalidade do seu personagem...">@Model.Character.PersonalityTraits</textarea>
                        </div>
                        <div class="p-4 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent">
                            <span class="text-[10px] font-bold text-primary uppercase">Ideais</span>
                            <textarea name="ideals"
                                    class="mt-1 w-full bg-transparent border-none p-0 text-sm leading-relaxed resize-none focus:ring-0 custom-scrollbar h-16"
                                    placeholder="Quais são os ideais do seu personagem?">@Model.Character.Ideals</textarea>
                        </div>
                    </div>
                </div>

                <!-- Equipment Preview -->
                <div class="p-6 rounded-xl border border-slate-200 dark:border-[#48232c] bg-white dark:bg-transparent">
                    <div class="flex justify-between items-center mb-4">
                        <h3 class="text-lg font-bold flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">backpack</span>
                            Equipamento
                        </h3>
                        <div class="flex gap-2 text-xs font-bold bg-slate-100 dark:bg-[#48232c] px-3 py-1 rounded-full">
                            <span class="text-yellow-600 dark:text-yellow-500">125 PO</span>
                            <span class="text-slate-400">|</span>
                            <span class="text-slate-500">42/150 lb</span>
                        </div>
                    </div>

                    <!-- sua lista visual de itens permanece aqui -->

                    <button class="w-full mt-4 py-2 text-primary font-bold text-sm border border-dashed border-primary/40 rounded-lg hover:bg-primary/5 transition-colors" type="button">
                        + Adicionar item
                    </button>

                    <div class="mt-4">
                        <label class="text-[10px] font-bold text-primary uppercase">Notas de equipamento</label>
                        <textarea name="equipmentNotes"
                                class="mt-1 w-full bg-transparent border border-border-dark/40 rounded-lg p-2 text-sm leading-relaxed resize-none focus:ring-1 focus:ring-primary custom-scrollbar h-20"
                                placeholder="Use este espaço para anotar itens especiais, mudanças de equipamento, etc.">@Model.Character.EquipmentNotes</textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>