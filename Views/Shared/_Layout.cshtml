<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - RPG-Builder</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,200..800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    "primary": "#d41152",
                    "background-light": "#f8f6f6",
                    "background-dark": "#221016",
                },
                fontFamily: {
                    "display": ["Work Sans", "sans-serif"]
                },
                borderRadius: {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
                },
            },
        },
    }
</script>


    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen">
    <div class="relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden">
        <div class="layout-container flex h-full grow flex-col">

            @{
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                bool isHome = currentController == "Home" && currentAction == "Index";
            }

            <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-primary/20 px-6 md:px-10 py-4 bg-background-light dark:bg-background-dark">
                <div class="flex items-center gap-4 text-primary">
                    <a asp-controller="Home"
                        asp-action="Index"
                        class="flex items-center gap-3 hover:opacity-90 transition-opacity">
                        <div class="size-8 flex items-center justify-center">
                            <span class="material-symbols-outlined text-3xl">swords</span>
                        </div>
                        <h2 class="text-slate-900 dark:text-slate-100 text-xl font-bold leading-tight tracking-tight font-display">
                            RPG-Builder
                        </h2>
                    </a>
                </div>

                <div class="flex flex-1 justify-end gap-4 md:gap-8 items-center">
                    @if (isHome)
                    {
                        <label class="hidden md:flex flex-col min-w-40 h-10 max-w-64">
                            <div class="flex w-full flex-1 items-stretch rounded-lg h-full overflow-hidden">
                                <div class="text-primary/70 flex border-none bg-primary/10 items-center justify-center pl-4">
                                    <span class="material-symbols-outlined">search</span>
                                </div>
                                <input
                                    class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden text-slate-900 dark:text-slate-100 focus:outline-0 focus:ring-0 border-none bg-primary/10 placeholder:text-primary/50 px-4 pl-2 text-base font-normal"
                                    placeholder="Buscar personagens..." value=""/>
                            </div>
                        </label>
                    }
                    <button class="flex items-center justify-center rounded-full h-10 w-10 bg-primary/10 text-primary">
                        <span class="material-symbols-outlined">account_circle</span>
                    </button>
                </div>
            </header>

            @RenderBody()

            <footer class="mt-20 py-8 px-6 md:px-20 border-t border-border bg-background">
                <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
                    <p class="text-muted-dark text-sm">© 2024 RPG-Builder. Todos os direitos reservados.</p>
                </div>
            </footer>

        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
