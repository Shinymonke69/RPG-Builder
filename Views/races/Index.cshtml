@model IEnumerable<RpgBuilderMvc.Domain.Entities.Race>

@{
    ViewData["Title"] = "Raças";
}

<section class="max-w-6xl mx-auto mt-8 px-6 md:px-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-2xl font-bold font-display text-slate-900 dark:text-slate-100">
                Raças SRD
            </h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">
                Lista de raças importadas da SRD 5e (ruleset 2014).
            </p>
        </div>
    </div>

    <div class="overflow-x-auto rounded-xl border border-border bg-white/80 dark:bg-slate-900/60 shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
            <thead class="bg-slate-50 dark:bg-slate-800">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                        Nome
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                        Velocidade
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                        Bônus de Habilidade
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                        Idiomas
                    </th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                        Traços
                    </th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
            @foreach (var r in Model)
            {
                <tr class="hover:bg-slate-50/80 dark:hover:bg-slate-800/60 transition-colors">
                    <td class="px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100">
                        @r.Name
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
                        @r.Speed
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
                        @r.AbilityBonuses
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
                        @r.Languages
                    </td>
                    <td class="px-4 py-3 text-sm text-slate-700 dark:text-slate-300">
                        @r.Traits
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>